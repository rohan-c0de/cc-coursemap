# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel — ignore contents (not the dir itself) so we can un-ignore project.json
.vercel/*
# ...but commit the project binding so `vercel` CLI always targets cc-coursemap
# (otherwise `vercel link --yes` auto-picks the `auditmap-virginia` project
# based on directory name). Only projectId/orgId/projectName — no secrets.
!.vercel/project.json

# supabase
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts
